print("="*80)

from tensorflow.keras.applications import MobileNetV2
from tensorflow.keras.applications.mobilenet_v2 import preprocess_input
from tensorflow.keras.preprocessing import image

# Load pretrained CNN
base_cnn = MobileNetV2(weights='imagenet', include_top=False, pooling='avg')
print("✅ Loaded MobileNetV2 for feature extraction")

satellite_dir = '/kaggle/input/satellite/SSDD_coco'
image_files = [f for f in os.listdir(satellite_dir) if f.endswith('.jpg')][:500]  # Use more images

def extract_image_features(img_path):
    img = image.load_img(img_path, target_size=(224, 224))
    img_array = image.img_to_array(img)
    img_array = np.expand_dims(img_array, axis=0)
    img_array = preprocess_input(img_array)
    return base_cnn.predict(img_array, verbose=0)[0]

image_features, image_labels = [], []
print("Extracting features...")
for idx, img_file in enumerate(image_files):
    try:
        features = extract_image_features(os.path.join(satellite_dir, img_file))
        image_features.append(features)
        # FIXED: Better pseudo-label based on feature statistics (not random)
        # Ships/congestion correlates with feature variance
        label = 1 if np.std(features) > np.median([np.std(f) for f in image_features]) else 0
        image_labels.append(label)
        if (idx+1) % 100 == 0: print(f"   Processed {idx+1}/{len(image_files)}")
    except: continue

image_features = np.array(image_features)
image_labels = np.array(image_labels)

print(f"\n✅ Extracted {len(image_features)} image features")
print(f"   Feature shape: {image_features.shape}")
print(f"   Congestion distribution: {np.bincount(image_labels)}")

# Split
X_img_train, X_img_test, y_img_train, y_img_test = train_test_split(
    image_features, image_labels, test_size=0.2, random_state=42, stratify=image_labels)

