# ============================================================================
# CELL 10: FAST MULTIMODAL FUSION - VECTORIZED IMPLEMENTATION
# ============================================================================

print("\n" + "="*80)
print("MULTIMODAL FUSION WITH DYNAMIC FEATURES (FAST VERSION)")
print("="*80)

print("📊 Creating multimodal features with vectorized operations...")

# 1. LSTM predictions (already have these)
lstm_preds_train = lstm_model.predict(X_train_lstm, batch_size=256, verbose=0).flatten()
lstm_preds_test = lstm_model.predict(X_test_lstm, batch_size=256, verbose=0).flatten()

print(f"✅ LSTM predictions: Train {lstm_preds_train.shape}, Test {lstm_preds_test.shape}")
print(f"   Range: {lstm_preds_train.min():.3f} to {lstm_preds_train.max():.3f}")

# 2. FAST GNN FEATURES - Vectorized
print("\n🕸️ Creating dynamic GNN features (vectorized)...")

# Get all node risks once
all_node_risks = gnn_model.predict(scaler_gnn.transform(node_features), verbose=0).flatten()
num_nodes = len(all_node_risks)

# Precompute node centralities
nodes_list = list(G.nodes())
centralities = np.array([nx.betweenness_centrality(G)[n] for n in nodes_list])

# VECTORIZED: Map all samples to nodes at once
category_indices_train = (X_train_scaled[:, 4] * 10).astype(int) % num_nodes
shipping_indices_train = (X_train_scaled[:, 9] * 5).astype(int) % num_nodes

category_indices_test = (X_test_scaled[:, 4] * 10).astype(int) % num_nodes
shipping_indices_test = (X_test_scaled[:, 9] * 5).astype(int) % num_nodes

# Get risks and centralities for all samples
cat_risks_train = all_node_risks[category_indices_train]
ship_risks_train = all_node_risks[shipping_indices_train]
cat_cent_train = centralities[category_indices_train]
ship_cent_train = centralities[shipping_indices_train]

cat_risks_test = all_node_risks[category_indices_test]
ship_risks_test = all_node_risks[shipping_indices_test]
cat_cent_test = centralities[category_indices_test]
ship_cent_test = centralities[shipping_indices_test]

# Compute weighted network risk
total_cent_train = cat_cent_train + ship_cent_train + 0.001
total_cent_test = cat_cent_test + ship_cent_test + 0.001

gnn_features_train = (cat_risks_train * cat_cent_train + ship_risks_train * ship_cent_train) / total_cent_train
gnn_features_test = (cat_risks_test * cat_cent_test + ship_risks_test * ship_cent_test) / total_cent_test

print(f"✅ GNN features: Train {gnn_features_train.shape}, Test {gnn_features_test.shape}")
print(f"   Range: {gnn_features_train.min():.3f} to {gnn_features_train.max():.3f}")
print(f"   Std: {gnn_features_train.std():.4f}")

# 3. FAST CNN FEATURES - Vectorized
print("\n🛰️ Creating dynamic CNN features (vectorized)...")

# Get all image predictions
all_image_preds = cnn_model.predict(X_img_train_scaled, batch_size=64, verbose=0).flatten()
num_images = len(all_image_preds)

# VECTORIZED: Compute congestion index for all samples
shipping_time_train = X_train_scaled[:, 0]
quantity_train = X_train_scaled[:, 6]
sales_train = X_train_scaled[:, 7]
profit_train = X_train_scaled[:, 8]

shipping_time_test = X_test_scaled[:, 0]
quantity_test = X_test_scaled[:, 6]
sales_test = X_test_scaled[:, 7]
profit_test = X_test_scaled[:, 8]

# Congestion indices
congestion_idx_train = ((shipping_time_train * quantity_train * sales_train * 1000).astype(int) % num_images)
congestion_idx_test = ((shipping_time_test * quantity_test * sales_test * 1000).astype(int) % num_images)

# Base congestion
base_congestion_train = all_image_preds[congestion_idx_train]
base_congestion_test = all_image_preds[congestion_idx_test]

# Profit modifier
modifier_train = 1.0 + 0.3 * (1 - profit_train)
modifier_test = 1.0 + 0.3 * (1 - profit_test)

# Final CNN features
cnn_features_train = np.clip(base_congestion_train * modifier_train, 0, 1)
cnn_features_test = np.clip(base_congestion_test * modifier_test, 0, 1)

print(f"✅ CNN features: Train {cnn_features_train.shape}, Test {cnn_features_test.shape}")
print(f"   Range: {cnn_features_train.min():.3f} to {cnn_features_train.max():.3f}")
print(f"   Std: {cnn_features_train.std():.4f}")

# Feature variation check
print("\n🔍 Feature Variation Analysis:")
print(f"   LSTM std: {lstm_preds_train.std():.4f}")
print(f"   GNN std:  {gnn_features_train.std():.4f}")
print(f"   CNN std:  {cnn_features_train.std():.4f}")

if gnn_features_train.std() < 0.01:
    print("   ⚠️ WARNING: GNN features have low variation!")
if cnn_features_train.std() < 0.01:
    print("   ⚠️ WARNING: CNN features have low variation!")

# Stack features
fusion_train = np.column_stack([lstm_preds_train, gnn_features_train, cnn_features_train])
fusion_test = np.column_stack([lstm_preds_test, gnn_features_test, cnn_features_test])

y_fusion_train = y_train
y_fusion_test = y_test

print(f"\n✅ Multimodal fusion data:")
print(f"   Train: {fusion_train.shape}")
print(f"   Test: {fusion_test.shape}")

# Feature correlations
print(f"\n📊 Feature Correlations with Label:")
for i, name in enumerate(['LSTM', 'GNN', 'CNN']):
    corr = np.corrcoef(fusion_train[:, i], y_fusion_train)[0, 1]
    print(f"   {name}: {corr:+.4f}")

# Build fusion model
input_layer = layers.Input(shape=(3,), name='fusion_input')

x = layers.Dense(128, activation='relu')(input_layer)
x = layers.BatchNormalization()(x)
x = layers.Dropout(0.4)(x)
x = layers.Dense(64, activation='relu')(x)
x = layers.BatchNormalization()(x)
x = layers.Dropout(0.3)(x)

# Attention
attention = layers.Dense(3, activation='softmax', name='attention')(x)

# Weighted features
weighted = layers.Multiply()([input_layer, attention])

# Output
x = layers.Dense(32, activation='relu')(weighted)
x = layers.Dropout(0.3)(x)
x = layers.Dense(16, activation='relu')(x)
output = layers.Dense(1, activation='sigmoid', name='prediction')(x)

fusion_model = Model(inputs=input_layer, outputs=[output, attention], name='Fusion')

fusion_model.compile(
    optimizer=keras.optimizers.Adam(0.0005),
    loss={'prediction': 'binary_crossentropy', 'attention': None},
    metrics={'prediction': ['accuracy', keras.metrics.AUC(name='auc')]}
)

print("\n📐 Fusion Model:")
fusion_model.summary()

# Train
print("\n🏋️ Training Fusion Model...")
history = fusion_model.fit(
    fusion_train,
    {'prediction': y_fusion_train, 'attention': np.zeros((len(y_fusion_train), 3))},
    validation_split=0.15,
    epochs=20,
    batch_size=512,
    callbacks=[
        EarlyStopping(patience=5, restore_best_weights=True, monitor='val_prediction_auc', mode='max'),
        ReduceLROnPlateau(monitor='val_prediction_auc', factor=0.5, patience=3, mode='max')
    ],
    verbose=1
)

# Predict
preds, attn = fusion_model.predict(fusion_test, batch_size=512, verbose=0)
y_pred = (preds > 0.5).astype(int).flatten()
y_proba = preds.flatten()

print("\n📊 Fusion Results:")
print(classification_report(y_fusion_test, y_pred, target_names=['On Time', 'Delayed']))
print(f"AUC: {roc_auc_score(y_fusion_test, y_proba):.4f}")
print(f"F1: {f1_score(y_fusion_test, y_pred):.4f}")
print(f"Acc: {accuracy_score(y_fusion_test, y_pred):.4f}")

# Attention analysis
attn_avg = attn.mean(axis=0)
attn_std = attn.std(axis=0)

print(f"\n⚡ Attention Weights:")
print(f"   LSTM: {attn_avg[0]:.3f} ± {attn_std[0]:.3f}")
print(f"   GNN:  {attn_avg[1]:.3f} ± {attn_std[1]:.3f}")
print(f"   CNN:  {attn_avg[2]:.3f} ± {attn_std[2]:.3f}")

# Compare to baseline
lstm_auc = roc_auc_score(y_test, y_pred_proba_lstm)
fusion_auc = roc_auc_score(y_fusion_test, y_proba)
improvement = ((fusion_auc - lstm_auc) / lstm_auc) * 100

print(f"\n📈 Performance:")
print(f"   LSTM:    {lstm_auc:.4f}")
print(f"   Fusion:  {fusion_auc:.4f}")
print(f"   Gain:    {improvement:+.2f}%")

if improvement > 0:
    print(f"   ✅ SUCCESS: Fusion improved over baseline!")
else:
    print(f"   ⚠️ No improvement (features may need refinement)")

# Quick visualization
fig, axes = plt.subplots(2, 3, figsize=(15, 8))

# 1. Feature distributions
axes[0,0].hist(fusion_train[:, 0], bins=50, alpha=0.6, label='LSTM', color='blue')
axes[0,0].hist(fusion_train[:, 1], bins=50, alpha=0.6, label='GNN', color='green')
axes[0,0].hist(fusion_train[:, 2], bins=50, alpha=0.6, label='CNN', color='purple')
axes[0,0].set_title('Feature Distributions')
axes[0,0].legend()

# 2. Attention weights
axes[0,1].bar(['LSTM', 'GNN', 'CNN'], attn_avg, yerr=attn_std, capsize=5,
