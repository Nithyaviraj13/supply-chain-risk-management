def predict_disruption(logistics_data, network_context=None, visual_context=None):
    """Complete prediction pipeline with multimodal fusion"""
    
    # LSTM prediction
    lstm_pred = lstm_model.predict(logistics_data, verbose=0)[0][0]
    
    # Network context (use mean if not provided)
    if network_context is None:
        network_context = gnn_mean_pred
    
    # Visual context (use mean if not provided)
    if visual_context is None:
        visual_context = cnn_mean_pred
    
    # Fusion
    fusion_input = np.array([[lstm_pred, network_context, visual_context]])
    final_pred, attn = fusion_model.predict(fusion_input, verbose=0)
    
    score = final_pred[0][0]
    
    # Risk assessment
    if score > 0.7:
        risk = "🚨 CRITICAL"
        recs = [
            "IMMEDIATE ACTION REQUIRED",
            f"Activate {best_route['name']}",
            "Contact all backup suppliers",
            "Increase inventory by 100%",
            "Daily monitoring required"
        ]
    elif score > 0.5:
        risk = "⚠️ HIGH"
        recs = [
            "Elevated monitoring",
            "Prepare contingency routes",
            "Alert supply chain team",
            "Review supplier contracts"
        ]
    elif score > 0.3:
        risk = "⚡ MEDIUM"
        recs = [
            "Standard monitoring",
            "Review next week's forecast",
            "Maintain safety stock"
        ]
    else:
        risk = "✅ LOW"
        recs = ["Normal operations", "Continue routine monitoring"]
    
    return {
        'score': float(score),
        'risk_level': risk,
        'components': {
            'logistics': float(lstm_pred),
            'network': float(network_context),
            'visual': float(visual_context)
        },
        'attention': {
            'logistics': float(attn[0][0]),
            'network': float(attn[0][1]),
            'visual': float(attn[0][2])
        },
        'recommendations': recs,
        'optimal_route': best_route
    }

# Test predictions
print("\n🔮 System Test - Sample Predictions:\n")

for i in range(min(5, len(X_test_lstm))):
