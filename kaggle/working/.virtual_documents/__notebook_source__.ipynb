    {'id': 1, 'name': 'Air Route (Express)', 'cost': 3500, 'time': 3, 'risk': 0.05, 'capacity': 500},
    {'id': 2, 'name': 'Land Route (Backup)', 'cost': 1800, 'time': 15, 'risk': 0.25, 'capacity': 2000},
