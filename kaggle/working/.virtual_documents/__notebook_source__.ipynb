print("\n" + "="*80)
print("MULTIMODAL FUSION WITH ATTENTION MECHANISM")
print("="*80)

# SOLUTION: Use LSTM as primary, replicate GNN/CNN predictions to match
print("📊 Preparing multimodal fusion data...")

# Get all predictions
lstm_preds_train = lstm_model.predict(X_train_lstm, batch_size=256, verbose=0)
lstm_preds_test = lstm_model.predict(X_test_lstm, batch_size=256, verbose=0)

print(f"LSTM predictions - Train: {lstm_preds_train.shape}, Test: {lstm_preds_test.shape}")

# For GNN and CNN: get predictions for their small datasets, then replicate
gnn_preds_all = gnn_model.predict(scaler_gnn.transform(node_features), verbose=0)
cnn_preds_all = cnn_model.predict(X_img_train_scaled, verbose=0)

# Take mean/representative prediction for each modality
gnn_mean_pred = np.mean(gnn_preds_all)
cnn_mean_pred = np.mean(cnn_preds_all)

print(f"GNN mean prediction: {gnn_mean_pred:.3f}")
print(f"CNN mean prediction: {cnn_mean_pred:.3f}")

# Create fusion features: LSTM prediction + GNN score + CNN score
# For each LSTM sample, add the network and visual context
fusion_train = np.column_stack([
    lstm_preds_train.flatten(),
    np.full(len(lstm_preds_train), gnn_mean_pred),  # Network risk (constant)
    np.full(len(lstm_preds_train), cnn_mean_pred)   # Visual congestion (constant)
])

fusion_test = np.column_stack([
    lstm_preds_test.flatten(),
    np.full(len(lstm_preds_test), gnn_mean_pred),
    np.full(len(lstm_preds_test), cnn_mean_pred)
])

y_fusion_train = y_train[:len(fusion_train)]
y_fusion_test = y_test[:len(fusion_test)]

print(f"\n✅ Fusion data prepared:")
print(f"   Train: {fusion_train.shape} samples")
print(f"   Test: {fusion_test.shape} samples")
print(f"   Features: [LSTM_pred, GNN_network_risk, CNN_visual_congestion]")

# Build simpler fusion model
input_layer = layers.Input(shape=(3,), name='fusion_input')

# Process with attention
x = layers.Dense(64, activation='relu')(input_layer)
x = layers.BatchNormalization()(x)
x = layers.Dropout(0.3)(x)

# Attention on the 3 input features
attention = layers.Dense(3, activation='softmax', name='attention_weights')(x)

# Apply attention to original inputs
weighted = layers.Multiply()([input_layer, attention])

# Final layers
x = layers.Dense(32, activation='relu')(weighted)
x = layers.Dropout(0.3)(x)
x = layers.Dense(16, activation='relu')(x)
output = layers.Dense(1, activation='sigmoid', name='disruption_prediction')(x)

fusion_model = Model(inputs=input_layer, outputs=[output, attention], name='Multimodal_Fusion')

fusion_model.compile(
    optimizer=keras.optimizers.Adam(0.0003),
    loss={'disruption_prediction': 'binary_crossentropy', 'attention_weights': None},
    metrics={'disruption_prediction': ['accuracy', keras.metrics.AUC(name='auc')]}
)

print("\n📐 Fusion Model Architecture:")
fusion_model.summary()

# Train
print("\n🏋️ Training Fusion Model...")
history_fusion = fusion_model.fit(
    fusion_train,
    {'disruption_prediction': y_fusion_train, 'attention_weights': np.zeros((len(y_fusion_train), 3))},
    validation_split=0.15,
    epochs=25,
    batch_size=256,
    callbacks=[
        EarlyStopping(patience=6, restore_best_weights=True, monitor='val_disruption_prediction_auc', mode='max'),
        ReduceLROnPlateau(monitor='val_disruption_prediction_auc', factor=0.5, patience=3, mode='max')
    ],
    verbose=1
)

# Predict
preds, attention = fusion_model.predict(fusion_test, verbose=0)
y_pred_fusion = (preds > 0.5).astype(int).flatten()
y_pred_proba_fusion = preds.flatten()

print("\n📊 Fusion Model Results:")
print(classification_report(y_fusion_test, y_pred_fusion, target_names=['On Time', 'Delayed']))
