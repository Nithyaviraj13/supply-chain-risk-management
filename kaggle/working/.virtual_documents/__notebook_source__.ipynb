]

print("📊 Available Routes:")
for r in routes:
    print(f"   {r['id']}: {r['name']}")
    print(f"      Cost: ${r['cost']}, Time: {r['time']}d, Risk: {r['risk']:.1%}, Capacity: {r['capacity']} units")

if QISKIT_AVAILABLE:
    print("\n⚛️ Using Quantum Optimization")
    from qiskit import QuantumCircuit
    from qiskit_aer import Aer
    
    qc = QuantumCircuit(4, 4)
    for i in range(4):
        qc.h(i)
    for i in range(3):
        qc.cx(i, i+1)
    qc.measure(range(4), range(4))
    
    simulator = Aer.get_backend('qasm_simulator')
    job = simulator.run(qc, shots=1000)
    result = job.result()
    counts = result.get_counts()
    
    best_state = max(counts, key=counts.get)
    best_route_id = int(best_state, 2) % len(routes)
    print(f"   Quantum state: {best_state} → Route {best_route_id}")
else:
    print("\n🔧 Using Classical Optimization")
    max_cost = max(r['cost'] for r in routes)
    max_time = max(r['time'] for r in routes)
    
    scores = [(r['cost']/max_cost * 0.4) + (r['time']/max_time * 0.3) + (r['risk'] * 0.3) for r in routes]
    best_route_id = np.argmin(scores)
    counts = None

best_route = routes[best_route_id]
print(f"\n🎯 Recommended Route: {best_route['name']}")
print(f"   Cost: ${best_route['cost']}, Time: {best_route['time']}d, Risk: {best_route['risk']:.1%}")
print(f"   Capacity: {best_route['capacity']} units")

