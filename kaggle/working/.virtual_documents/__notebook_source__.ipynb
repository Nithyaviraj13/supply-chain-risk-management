# CELL 3: LOAD & EXPLORE SUPPLYGRAPH DATASET
# ============================================================================
print("\n" + "="*80)
print("LOADING SUPPLYGRAPH DATASET")
print("="*80)

# Load all components
nodes = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Nodes/Nodes.csv')
nodes_index = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Nodes/NodesIndex.csv')
node_types = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Nodes/Node Types (Product Group and Subgroup).csv')

edges_plant = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Edges/EdgesIndex/Edges (Plant).csv')
edges_group = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Edges/EdgesIndex/Edges (Product Group).csv')
edges_storage = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Edges/EdgesIndex/Edges (Storage Location).csv')

temp_delivery = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Temporal Data/Unit/Delivery To distributor.csv')
temp_factory = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Temporal Data/Unit/Factory Issue.csv')
temp_production = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Temporal Data/Unit/Production .csv')
temp_sales = pd.read_csv('/kaggle/input/supplygraph-supply-chain-planning-using-gnns/Raw Dataset/Temporal Data/Unit/Sales Order.csv')

print(f"\n🕸️ Graph Structure:")
print(f"   Nodes: {len(nodes)}")
print(f"   Edges: {len(edges_plant) + len(edges_group) + len(edges_storage):,}")
print(f"   Temporal Points: {len(temp_production)}")
print(f"   Products: {len(temp_production.columns)-1}")

# Build Network Graph
G = nx.Graph()

for _, row in nodes_index.iterrows():
    node_id, node_name = row['NodeIndex'], row['Node']
    type_info = node_types[node_types['Node']==node_name]
    G.add_node(node_id, 
               name=node_name,
               group=type_info['Group'].values[0] if len(type_info)>0 else 'Unknown')

for _, row in edges_plant.iterrows():
    G.add_edge(row['node1'], row['node2'], type='plant')
    
for _, row in edges_group.iterrows():
    G.add_edge(row['node1'], row['node2'], type='group')
    
for _, row in edges_storage.iterrows():
    G.add_edge(int(row['node1']), int(row['node2']), type='storage')

print(f"\n📊 Network Metrics:")
print(f"   Density: {nx.density(G):.4f}")
print(f"   Avg Degree: {sum(dict(G.degree()).values())/G.number_of_nodes():.2f}")

# Visualizations
fig, axes = plt.subplots(2, 2, figsize=(14, 12))

# 1. Network Graph
pos = nx.spring_layout(G, k=0.5, seed=42)
color_map = {'S':'red', 'P':'blue', 'A':'green', 'M':'orange', 'E':'purple'}
node_colors = [color_map.get(G.nodes[n].get('group','Unknown'), 'gray') for n in G.nodes()]

nx.draw_networkx_nodes(G, pos, node_color=node_colors, node_size=300, alpha=0.7, ax=axes[0,0])
nx.draw_networkx_edges(G, pos, alpha=0.2, width=0.5, ax=axes[0,0])
axes[0,0].set_title('🕸️ Supply Chain Network', fontweight='bold', fontsize=12)
axes[0,0].axis('off')

# 2. Production Time Series
temp_production['Date'] = pd.to_datetime(temp_production['Date'])
temp_production.set_index('Date').iloc[:,:5].plot(ax=axes[0,1], linewidth=1.5)
axes[0,1].set_title('📈 Production Time Series', fontweight='bold', fontsize=12)
