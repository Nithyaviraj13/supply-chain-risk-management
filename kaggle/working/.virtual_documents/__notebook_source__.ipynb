axes[0,1].set_ylim(0, 1)

# 3. Training
axes[0,2].plot(history.history['prediction_auc'], label='Train')
axes[0,2].plot(history.history['val_prediction_auc'], label='Val')
axes[0,2].set_title('Training AUC')
axes[0,2].legend()

# 4. Confusion matrix
cm = confusion_matrix(y_fusion_test, y_pred)
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[1,0])
