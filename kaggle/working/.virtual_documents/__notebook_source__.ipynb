def analyze_dataframe(df, name):
    """Comprehensive analysis of a DataFrame"""
    print(f"\n{'='*100}")
    print(f"📊 ANALYZING: {name}".center(100))
    print(f"{'='*100}\n")
    
    # Basic Info
    print("📋 BASIC INFORMATION:")
    print(f"   • Total Rows: {len(df):,}")
    print(f"   • Total Columns: {len(df.columns)}")
    print(f"   • Memory Usage: {df.memory_usage(deep=True).sum() / 1024**2:.2f} MB")
    print(f"   • Duplicates: {df.duplicated().sum():,}")
    
    # Column Info
    print(f"\n📝 COLUMN DETAILS:")
    col_info = pd.DataFrame({
        'Column': df.columns,
        'Type': df.dtypes.values,
        'Non-Null': df.count().values,
        'Null': df.isnull().sum().values,
        'Null %': (df.isnull().sum() / len(df) * 100).round(2).values,
        'Unique': [df[col].nunique() for col in df.columns],
        'Sample Values': [str(df[col].dropna().head(3).tolist())[:60] + '...' for col in df.columns]
    })
    print(col_info.to_string(index=False))
    
    # Numeric columns statistics
    numeric_cols = df.select_dtypes(include=[np.number]).columns
    if len(numeric_cols) > 0:
        print(f"\n📈 NUMERIC COLUMNS STATISTICS:")
        print(df[numeric_cols].describe().round(2))
    
    # Categorical columns
    categorical_cols = df.select_dtypes(include=['object']).columns
    if len(categorical_cols) > 0 and len(categorical_cols) <= 20:
        print(f"\n📊 CATEGORICAL COLUMNS (Top 5 values each):")
        for col in categorical_cols[:10]:  # Limit to first 10
            print(f"\n   {col}:")
            print(df[col].value_counts().head(5))
    
    # Data Preview
    print(f"\n👁️ DATA PREVIEW (First 5 rows):")
    print(df.head())
    
    return col_info

