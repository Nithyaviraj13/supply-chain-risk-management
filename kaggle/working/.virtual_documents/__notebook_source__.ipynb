print("\n" + "="*80)
print("DATA PREPROCESSING: SUPPLYGRAPH TEMPORAL DATA")
print("="*80)

# Prepare temporal sequences for LSTM
temporal_cols = [c for c in temp_production.columns if c != 'Date']
temporal_data = temp_production[temporal_cols].values  # (221, 41)

print(f"✅ Temporal data: {temporal_data.shape}")

# Create sequences (sliding window)
SEQ_LENGTH = 10
def create_sequences(data, seq_len):
    X, y = [], []
    for i in range(len(data) - seq_len):
        X.append(data[i:i+seq_len])
        # Predict if next timestep has issues (use factory issues as label)
        next_issues = temp_factory.iloc[i+seq_len, 1:].values
        y.append(1 if np.sum(next_issues > 0) > len(next_issues)//2 else 0)
    return np.array(X), np.array(y)

X_temp, y_temp = create_sequences(temporal_data, SEQ_LENGTH)
print(f"✅ Created {len(X_temp)} sequences of length {SEQ_LENGTH}")

# Split
X_temp_train, X_temp_test, y_temp_train, y_temp_test = train_test_split(
    X_temp, y_temp, test_size=0.2, random_state=42)

# Normalize
scaler_temporal = StandardScaler()
X_temp_train_flat = X_temp_train.reshape(-1, X_temp_train.shape[-1])
scaler_temporal.fit(X_temp_train_flat)

X_temp_train_scaled = scaler_temporal.transform(
    X_temp_train.reshape(-1, X_temp_train.shape[-1])).reshape(X_temp_train.shape)
X_temp_test_scaled = scaler_temporal.transform(
    X_temp_test.reshape(-1, X_temp_test.shape[-1])).reshape(X_temp_test.shape)

print(f"   Train: {X_temp_train_scaled.shape}, Labels: {np.sum(y_temp_train)} positive")
print(f"   Test: {X_temp_test_scaled.shape}, Labels: {np.sum(y_temp_test)} positive")

# FIXED: Better GNN node features using ALL temporal data
node_features = []
for col_idx in range(min(G.number_of_nodes(), len(temporal_cols))):
    col_data = temporal_data[:, col_idx]
    feats = [
        np.mean(col_data), 
        np.std(col_data),
        np.max(col_data), 
        np.min(col_data),
        np.percentile(col_data, 25),  # Added quartiles
        np.percentile(col_data, 75),
        np.sum(col_data > 0) / len(col_data)  # Activity rate
    ]
    node_features.append(feats)

node_features = np.array(node_features)
# Pad if needed
while len(node_features) < G.number_of_nodes():
    node_features = np.vstack([node_features, node_features[-1]])
node_features = node_features[:G.number_of_nodes()]

# FIXED: Better labels using actual disruption data from factory issues
# Use mean factory issues as risk indicator
factory_data = temp_factory.iloc[:, 1:].values
node_risk_scores = np.mean(factory_data, axis=0)[:G.number_of_nodes()]
node_labels = (node_risk_scores > np.median(node_risk_scores)).astype(int)

print(f"\n🕸️ GNN Data:")
print(f"   Node features shape: {node_features.shape}")
print(f"   Class distribution: {np.bincount(node_labels)}")

# Split GNN data with balanced split
from sklearn.model_selection import StratifiedShuffleSplit
sss = StratifiedShuffleSplit(n_splits=1, test_size=0.3, random_state=42)
for train_idx, test_idx in sss.split(node_features, node_labels):
    X_gnn_train, X_gnn_test = node_features[train_idx], node_features[test_idx]
    y_gnn_train, y_gnn_test = node_labels[train_idx], node_labels[test_idx]

scaler_gnn = StandardScaler()
X_gnn_train_scaled = scaler_gnn.fit_transform(X_gnn_train)
X_gnn_test_scaled = scaler_gnn.transform(X_gnn_test)

print(f"   Train: {X_gnn_train_scaled.shape}, Labels: {np.bincount(y_gnn_train)}")
print(f"   Test: {X_gnn_test_scaled.shape}, Labels: {np.bincount(y_gnn_test)}")

# Save
pickle.dump(scaler_temporal, open('/kaggle/working/models/scaler_temporal.pkl', 'wb'))
pickle.dump(scaler_gnn, open('/kaggle/working/models/scaler_gnn.pkl', 'wb'))

